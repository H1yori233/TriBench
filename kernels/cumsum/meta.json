{
    "schema_version": "1.0",
    "name": "cumsum",
    "family": "reduction",
    "description": "Cumulative Sum",
    "source": "https://github.com/flagos-ai/FlagGems/blob/master/src/flag_gems/ops/cumsum.py",
    "tags": [
        "reduction",
        "flaggems"
    ],
    "entrypoints": {
        "make_inputs": "reference.py:make_inputs",
        "reference": "reference.py:ref",
        "triton": "triton_impl.py:run"
    },
    "supported": {
        "dtypes": [
            "fp16",
            "bf16",
            "fp32"
        ],
        "layouts": [
            "contiguous"
        ],
        "backends": [
            "cuda"
        ]
    },
    "cases": [
        {
            "name": "small",
            "B": 64,
            "N": 1024
        },
        {
            "name": "large",
            "B": 16,
            "N": 16384
        }
    ],
    "correctness": {
        "atol": 1e-1,
        "rtol": 1e-1,
        "per_dtype": {
            "fp32": {
                "atol": 1e-4,
                "rtol": 1e-3
            }
        }
    },
    "metrics": "elementwise"
}