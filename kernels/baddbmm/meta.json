            "B": 64,
            "M": 128,
            "N": 128,
            "K": 128
        },
        {
            "name": "batch_32_512x512",
            "B": 32,
            "M": 512,
            "N": 512,
            "K": 512
        }
    ],
    "correctness": {
        "atol": 1e-2,
        "rtol": 1e-2,
        "per_dtype": {
            "fp32": {
                "atol": 1e-5,
                "rtol": 1e-4
            }
        }
    },
    "metrics": "blas"
}