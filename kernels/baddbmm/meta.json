{
    "schema_version": "1.0",
    "name": "baddbmm",
    "family": "blas",
    "description": "Batch Add Matrix Multiplication",
    "source": "https://github.com/flagos-ai/FlagGems/blob/master/src/flag_gems/ops/baddbmm.py",
    "tags": [
        "blas",
        "flaggems"
    ],
    "entrypoints": {
        "make_inputs": "reference.py:make_inputs",
        "reference": "reference.py:ref",
        "triton": "triton_impl.py:run",
        "backward": "triton_impl.py:run_backward"
    },
    "supported": {
        "dtypes": [
            "fp16",
            "bf16",
            "fp32"
        ],
