{
    "schema_version": "1.0",
    "name": "rms_norm",
    "family": "normalization",
    "description": "Root Mean Square Layer Normalization (RMSNorm)",
    "tags": [
        "normalization",
        "liger-kernel"
    ],
    "entrypoints": {
        "make_inputs": "reference.py:make_inputs",
        "reference": "reference.py:ref",
        "triton": "triton_impl.py:run",
        "backward": "triton_impl.py:run_backward"
    },
    "supported": {
        "dtypes": [
            "fp16",
            "bf16",
            "fp32"
