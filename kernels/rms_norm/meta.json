            "T": 4096,
            "H": 4096
        },
        {
            "name": "llama3_70b",
            "B": 1,
            "T": 4096,
            "H": 8192
        }
    ],
    "correctness": {
        "atol": 1e-2,
        "rtol": 1e-2,
        "per_dtype": {
            "fp32": {
